# Copy this file to .env and fill in values to override the defaults baked
# into the code. All VITE_* variables are embedded in the client bundle at
# build time, so never put secret (service-role) keys here.

# Supabase project (defaults to the Rainbow Navigator project)
VITE_SUPABASE_URL=https://wpzjeodswvbneylbkwid.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_kp6WLDXRQQPdaPWbXVR8TQ_cXFwHAnC

# Google Maps browser key (restrict by HTTP referrer in Google Cloud Console)
VITE_GOOGLE_MAPS_API_KEY=

# Base path for routing (defaults to /)
VITE_BASE_PATH=
